{% comment %}
  Minimal custom header for the product page only.
  Links point back to the Next.js storefront (gweelherbals.com), not Shopify.
{% endcomment %}

<style>
  .gweel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem 4rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
    font-family: inherit;
  }
  .gweel-header__logo {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #111;
    text-decoration: none;
    white-space: nowrap;
  }
  .gweel-header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .gweel-header__nav a {
    font-size: 1rem;
    color: #111;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .gweel-header__nav a:hover {
    opacity: 0.6;
  }
  @media (max-width: 640px) {
    .gweel-header {
      padding: 1rem 1.25rem;
      gap: 1rem;
    }
    .gweel-header__nav {
      gap: 1.25rem;
    }
    .gweel-header__nav a {
      font-size: 0.9rem;
    }
  }
</style>

<header class="gweel-header">
  <a href="https://www.gweelherbals.com/" class="gweel-header__logo">GWEEL HERBALS</a>
  <nav class="gweel-header__nav">
    <a href="https://www.gweelherbals.com/">Home</a>
    <a href="https://www.gweelherbals.com/shop">Catalog</a>
    <a href="https://www.gweelherbals.com/contact">Contact us</a>
  </nav>
</header>
