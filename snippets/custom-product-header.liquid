{% comment %}
  Floating rounded pill header for the product page only.
  Links point back to the Next.js storefront (gweelherbals.com).
  Cart count updates live via the `cart:updated` event from the product section.
{% endcomment %}

{% render 'cart-drawer' %}

<div class="gweel-header__bar">
  <header class="gweel-header">
    <nav class="gweel-header__left">
      <a href="https://www.gweelherbals.com/">Home</a>
      <a href="https://www.gweelherbals.com/shop">Catalog</a>
      <a href="https://www.gweelherbals.com/contact">Contact us</a>
    </nav>

    <a href="https://www.gweelherbals.com/" class="gweel-header__logo">Gweel Herbals</a>

    <div class="gweel-header__right">
      <a href="{{ routes.cart_url }}" class="gweel-header__cart" data-cart-open aria-label="Open cart">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"></path>
        </svg>
        <span>Cart</span>
        <span class="gweel-header__cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </header>
</div>

<style>
  .gweel-header__bar {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 44px clamp(12px, 4vw, 48px) 16px;
    background: transparent;
  }
  .gweel-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    height: 64px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 12px 0 32px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(120,120,120,.92), rgba(90,90,90,.92));
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0,0,0,.18);
    font-family: inherit;
  }
  .gweel-header__left {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .gweel-header__left a {
    color: #fff;
    text-decoration: none;
    font-size: 1rem;
    opacity: .92;
    transition: opacity .15s;
    white-space: nowrap;
  }
  .gweel-header__left a:hover { opacity: 1; }
  .gweel-header__logo {
    color: #fff;
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 700;
    white-space: nowrap;
    justify-self: center;
  }
  .gweel-header__right {
    display: flex;
    justify-content: flex-end;
  }
  .gweel-header__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 999px;
    background: #f5c542;
    color: #1a1a1a;
    text-decoration: none;
    font-weight: 400;
    font-size: .95rem;
    transition: background .15s, transform .05s;
  }
  .gweel-header__cart:hover { background: #f1bd2c; }
  .gweel-header__cart:active { transform: scale(.98); }
  .gweel-header__cart-count {
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 999px;
    background: #1a1a1a;
    color: #fff;
    font-size: .75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 760px) {
    .gweel-header {
      grid-template-columns: 1fr auto;
      padding: 12px 14px 12px 18px;
      gap: 10px;
    }
    .gweel-header__left { display: none; }
    .gweel-header__logo { justify-self: start; font-size: 1.1rem; }
    .gweel-header__cart span:not(.gweel-header__cart-count) { display: none; }
    .gweel-header__cart { padding: 10px 14px; }
  }
</style>

<script>
  (function () {
    document.addEventListener('cart:updated', function (e) {
      var count = e.detail && typeof e.detail.count === 'number' ? e.detail.count : null;
      if (count === null) return;
      document.querySelectorAll('[data-cart-count]').forEach(function (el) {
        el.textContent = count;
        el.hidden = count === 0;
      });
    });
  })();
</script>
